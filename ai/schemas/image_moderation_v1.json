{
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"schema_version": { "type": "string", "enum": ["v1"] },
		"action_taken": { "type": "string", "enum": ["allow", "block", "review"] },
		"moderation_status": { "type": "string", "enum": ["approved", "rejected", "needs_review"] },
		"nsfw_score": { "type": "number", "minimum": 0, "maximum": 1 },
		"relevance_score": { "type": "number", "minimum": 0, "maximum": 1 },
		"confidence": { "type": "number", "minimum": 0, "maximum": 1 },
		"labels": { "type": "array", "items": { "type": "string" } },
		"reasons": { "type": "array", "items": { "type": "string" } },
		"requires_human_review": { "type": "boolean" }
	},
	"required": ["schema_version", "action_taken", "moderation_status", "nsfw_score", "relevance_score", "confidence", "labels", "reasons", "requires_human_review"]
}
